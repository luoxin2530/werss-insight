WERSS_BASE_URL=http://we-mp-rss:8001
WERSS_ACCESS_KEY=
WERSS_SECRET_KEY=

# Docker Compose helpers. Use /vol1/1000/werss-insight/data on your server if desired.
WERSS_INSIGHT_PORT=8765
WERSS_INSIGHT_DATA_DIR=./data

# Any OpenAI-compatible /chat/completions endpoint.
ALLOW_LLM=true
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120
MAX_ARTICLE_CHARS=12000

# Run a full sync + summary + author profile update every 3 days at 09:00.
AUTO_RUN=true
SCHEDULE_DAYS=3
SCHEDULE_TIME=09:00
SYNC_LIMIT=100

# Article image handling.
MEDIA_CACHE_MODE=optimized_local
MEDIA_MAX_WIDTH=1800
MEDIA_IMAGE_QUALITY=85
MEDIA_PREFER_WEBP=true

# Knowledge-base Q&A. Uses an OpenAI-compatible /embeddings endpoint.
RAG_ENABLED=true
RAG_API_BASE_URL=https://api.openai.com/v1
RAG_API_KEY=
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4o-mini
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=140
RAG_TOP_K=8

# Optional: send top reading items after scheduled updates.
NOTIFY_WEBHOOK_URL=
NOTIFY_MIN_SCORE=7.5
NOTIFY_TOP_N=8
