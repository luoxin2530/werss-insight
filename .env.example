WERSS_BASE_URL=http://192.168.68.100:8011
WERSS_ACCESS_KEY=
WERSS_SECRET_KEY=

# Any OpenAI-compatible /chat/completions endpoint.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120

# Runs a full sync + summary + author profile update every 3 days at 09:00.
AUTO_RUN=true
SCHEDULE_DAYS=3
SCHEDULE_TIME=09:00

SYNC_LIMIT=100
MAX_ARTICLE_CHARS=12000
ALLOW_LLM=true

# Optional: send top reading items after scheduled updates.
NOTIFY_WEBHOOK_URL=
NOTIFY_MIN_SCORE=7.5
NOTIFY_TOP_N=8
